---
const title = "Jimmy-Bean Runs";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: dark;
        --bg-1: #0c0a07;
        --bg-2: #1a120a;
        --text: #f4ead3;
        --muted: #b9a888;
        --accent: #f6c453;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; height: 100%; }
      body {
        background: radial-gradient(ellipse at center, var(--bg-2) 0%, var(--bg-1) 70%);
        color: var(--text);
        font-family: "VT323", monospace;
        font-size: 20px;
        line-height: 1.45;
        overflow: hidden;
      }

      .landing {
        display: grid;
        grid-template-rows: auto 1fr auto;
        height: 100vh;
        padding: 24px;
      }

      .landing-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
      }
      .brand {
        font-family: "Press Start 2P", monospace;
        font-size: 12px;
        letter-spacing: 0.18em;
        color: var(--accent);
      }
      .nav-links a {
        color: var(--muted);
        text-decoration: none;
        margin-left: 16px;
        font-size: 16px;
      }
      .nav-links a:hover { color: var(--accent); }

      #bookStage {
        position: relative;
        width: 100%;
        height: 100%;
        min-height: 420px;
        overflow: hidden;
      }
      #bookStage canvas {
        position: absolute;
        inset: 0;
        width: 100% !important;
        height: 100% !important;
        display: block;
        z-index: 0;
      }

      .stage-controls {
        position: absolute;
        inset: 0;
        pointer-events: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 12px;
        z-index: 2;
      }
      .nav-arrow {
        pointer-events: auto;
        background: rgba(20, 12, 6, 0.6);
        border: 1px solid #5b3e1f;
        color: var(--text);
        width: 44px;
        height: 44px;
        border-radius: 50%;
        font-size: 22px;
        cursor: pointer;
        transition: transform 120ms ease, border-color 120ms ease, opacity 120ms ease;
      }
      .nav-arrow:hover:not(:disabled) {
        transform: translateY(-1px);
        border-color: var(--accent);
        color: var(--accent);
      }
      .nav-arrow:disabled { opacity: 0.25; cursor: not-allowed; }

      .landing-footer {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
      }

      #pageDots {
        display: flex;
        gap: 8px;
      }
      .page-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(246, 196, 83, 0.18);
        border: 1px solid rgba(246, 196, 83, 0.35);
        cursor: pointer;
        padding: 0;
        transition: transform 120ms ease, background 120ms ease;
      }
      .page-dot:hover { background: rgba(246, 196, 83, 0.4); }
      .page-dot.is-active {
        background: var(--accent);
        transform: scale(1.2);
      }

      #openChapter {
        font-family: "Press Start 2P", monospace;
        font-size: 11px;
        letter-spacing: 0.16em;
        padding: 12px 22px;
        background: var(--accent);
        color: #1a120a;
        border: 0;
        cursor: pointer;
        text-transform: uppercase;
        transition: filter 120ms ease;
      }
      #openChapter:hover:not(:disabled) { filter: brightness(1.1); }
      #openChapter:disabled { opacity: 0.4; cursor: not-allowed; }

      .hint { color: var(--muted); font-size: 14px; margin: 0; }
    </style>
  </head>
  <body>
    <div class="landing">
      <header class="landing-header">
        <div class="brand">Jimmy-Bean Runs</div>
        <nav class="nav-links">
          <a id="adminLink" href="/admin" hidden>Admin</a>
        </nav>
      </header>

      <div id="bookStage">
        <div class="stage-controls">
          <button id="prevPage" class="nav-arrow" aria-label="Previous chapter" disabled>‹</button>
          <button id="nextPage" class="nav-arrow" aria-label="Next chapter" disabled>›</button>
        </div>
      </div>

      <footer class="landing-footer">
        <div id="pageDots"></div>
        <button id="openChapter" disabled>Open chapter</button>
        <p class="hint">Use ← → to flip pages · Enter to open</p>
      </footer>
    </div>

    <script>
      import "../scripts/landing/main.js";
    </script>
  </body>
</html>
